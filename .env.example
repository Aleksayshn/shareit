PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=shareit
DB_USERNAME=postgres
DB_PASSWORD=change-me

app.security.jwt.secret=replace-with-a-random-32-char-min-secret
app.security.jwt.expiration=24h

app.security.cors.allowed-origins=http://localhost:3000,http://localhost:5173
app.security.cors.allowed-methods=GET,POST,PUT,PATCH,DELETE,OPTIONS
app.security.cors.allowed-headers=*
app.security.cors.exposed-headers=Authorization,Location
